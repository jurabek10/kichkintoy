{
  "name": "kichkintoy",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.19.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @kichkintoy/api dev",
    "dev:web": "pnpm --filter @kichkintoy/web dev",
    "dev:web:3001": "pnpm --filter @kichkintoy/web dev:3001",
    "dev:home": "pnpm --filter @kichkintoy/home dev",
    "dev:mobile": "pnpm --filter @kichkintoy/mobile dev",
    "stop:api": "node scripts/kill-port.mjs 4000",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "pnpm --filter @kichkintoy/api db:reset",
    "db:migrate": "pnpm --filter @kichkintoy/api db:migrate",
    "db:generate": "pnpm --filter @kichkintoy/api db:generate",
    "db:studio": "pnpm --filter @kichkintoy/api db:studio",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "react-native": "0.81.5",
      "@react-native/metro-config": "0.81.5",
      "@react-native/babel-preset": "0.81.5"
    }
  }
}
