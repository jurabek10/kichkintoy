{
  "name": "@kichkintoy/mobile-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Code shared by the parent (mobile) and teacher (teacher-mobile) Expo apps — consumed as source, transpiled by each app's Metro/Babel.",
  "exports": {
    "./theme": { "types": "./src/theme.ts", "default": "./src/theme.ts" },
    "./utils": { "types": "./src/utils.ts", "default": "./src/utils.ts" },
    "./date": { "types": "./src/date.ts", "default": "./src/date.ts" },
    "./config": { "types": "./src/config.ts", "default": "./src/config.ts" },
    "./report-item-i18n": { "types": "./src/report-item-i18n.ts", "default": "./src/report-item-i18n.ts" },
    "./notification-visuals": { "types": "./src/notification-visuals.ts", "default": "./src/notification-visuals.ts" },
    "./messages": { "types": "./src/messages.tsx", "default": "./src/messages.tsx" },
    "./complaints": { "types": "./src/complaints.tsx", "default": "./src/complaints.tsx" }
  },
  "dependencies": {
    "@kichkintoy/shared": "workspace:*",
    "@kichkintoy/translations": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "expo-constants": "~18.0.13",
    "@expo/vector-icons": "^15.0.3",
    "@tanstack/react-query": "^5.100.14",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-sharing": "~14.0.8"
  },
  "peerDependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "i18next": "*",
    "react-i18next": "*",
    "@tanstack/react-query": "^5.100.14",
    "react-native-safe-area-context": "~5.6.0",
    "expo": "~54.0.34",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-sharing": "~14.0.8"
  }
}
