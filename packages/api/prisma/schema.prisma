model Payment {
  id                    String    @id @default(uuid()) @db.Uuid
  // Sequential integer id: Click's SHOP-API expects an integer merchant_prepare_id.
  seq                   Int       @unique @default(autoincrement())
  invoiceId             String    @map("invoice_id") @db.Uuid
  provider              String
  providerTransactionId String?   @map("provider_transaction_id")
  // Payme Merchant API transaction state: 1 created, 2 performed, -1/-2 cancelled.
  providerState         Int?      @map("provider_state")
  cancelReason          Int?      @map("cancel_reason")
  cancelledAt           DateTime? @map("cancelled_at") @db.Timestamptz(6)
  amount                Decimal   @db.Decimal(14, 2)
  currency              String    @default("UZS")
  status                String    @default("pending")
  paidAt                DateTime? @map("paid_at") @db.Timestamptz(6)
  rawPayload            Json?     @map("raw_payload") @db.JsonB
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([provider, providerTransactionId])
  @@index([invoiceId])
  @@map("payments")
}

