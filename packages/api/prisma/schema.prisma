generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  legalName       String?  @map("legal_name")
  taxId           String?  @map("tax_id")
  phone           String?
  email           String?
  defaultLanguage String   @default("uz") @map("default_language")
  timezone        String   @default("Asia/Tashkent")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  branches  Branch[]
  centers   Center[]
  userRoles UserRole[]
  auditLogs AuditLog[]

  @@map("organizations")
}

model Center {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  name                 String
  centerCode           String   @unique @map("center_code")
  facilityType         String   @default("kindergarten") @map("facility_type")
  phone                String?
  address              String?
  regionId             String?  @map("region_id") @db.Uuid
  districtId           String?  @map("district_id") @db.Uuid
  region               String?
  district             String?
  status               String   @default("active")
  // Monthly tuition fee in UZS charged per enrolled child; the source of truth
  // for lazily generated monthly invoices and the director tuition console.
  monthlyTuitionUzs    Decimal  @default(1000000) @map("monthly_tuition_uzs") @db.Decimal(14, 2)
  // Platform subscription the center pays the founder each month:
  // total = platformBaseFeeUzs + activeKids * platformPerKidFeeUzs.
  platformBaseFeeUzs   Decimal  @default(300000) @map("platform_base_fee_uzs") @db.Decimal(14, 2)
  platformPerKidFeeUzs Decimal  @default(30000) @map("platform_per_kid_fee_uzs") @db.Decimal(14, 2)
  // Day of month (1–28) the center pays the platform — its "payment date".
  platformBillingDay   Int      @default(1) @map("platform_billing_day")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization               Organization                @relation(fields: [organizationId], references: [id])
  regionRef                  Region?                     @relation(fields: [regionId], references: [id])
  districtRef                District?                   @relation(fields: [districtId], references: [id])
  albumPosts                 AlbumPost[]
  attendanceRecords          AttendanceRecord[]
  auditLogs                  AuditLog[]
  branches                   Branch[]
  calendarEvents             CalendarEvent[]
  centerInvitations          CenterInvitation[]
  centerJoinRequests         CenterJoinRequest[]
  childEnrollments           ChildEnrollment[]
  classes                    Class[]
  conversationThreads        ConversationThread[]
  complaints                 Complaint[]
  dailyReports               DailyReport[]
  invoices                   Invoice[]
  platformPayments           CenterPlatformPayment[]
  mealPlans                  MealPlan[]
  mealPosts                  MealPost[]
  mediaAssets                MediaAsset[]
  medicationRequests         MedicationRequest[]
  notices                    Notice[]
  pickupTimeNotices          PickupTimeNotice[]
  returnHomeRequests         ReturnHomeRequest[]
  schedules                  Schedule[]
  studentDocumentTemplates   StudentDocumentTemplate[]
  studentDocumentRequests    StudentDocumentRequest[]
  studentDocumentSubmissions StudentDocumentSubmission[]
  userRoles                  UserRole[]

  @@index([organizationId])
  @@index([name])
  @@index([regionId, districtId])
  @@index([facilityType])
  @@map("centers")
}

model Region {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  slug         String   @unique
  countryCode  String   @default("UZ") @map("country_code")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  centers   Center[]
  districts District[]

  @@map("regions")
}

model District {
  id           String   @id @default(uuid()) @db.Uuid
  regionId     String   @map("region_id") @db.Uuid
  name         String
  slug         String
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  region  Region   @relation(fields: [regionId], references: [id])
  centers Center[]

  @@unique([regionId, slug])
  @@index([regionId])
  @@map("districts")
}

model Branch {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  centerId       String   @map("center_id") @db.Uuid
  name           String
  address        String?
  phone          String?
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  center       Center       @relation(fields: [centerId], references: [id])
  classes      Class[]
  userRoles    UserRole[]

  @@index([organizationId])
  @@index([centerId])
  @@map("branches")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  username          String?   @unique
  phone             String?   @unique
  email             String?   @unique
  fullName          String    @map("full_name")
  avatarUrl         String?   @map("avatar_url")
  preferredLanguage String    @default("uz") @map("preferred_language")
  telegramId        BigInt?   @unique @map("telegram_id")
  telegramUsername  String?   @map("telegram_username")
  status            String    @default("active")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  authCredential              AuthCredential?
  authSessions                AuthSession[]
  albumComments               AlbumComment[]
  noticeComments              NoticeComment[]
  albumPosts                  AlbumPost[]
  albumReactions              AlbumReaction[]
  auditLogs                   AuditLog[]                  @relation("AuditActor")
  calendarEvents              CalendarEvent[]
  calendarEventSeen           CalendarEventSeen[]
  centerInvitationsAccepted   CenterInvitation[]          @relation("CenterInvitationAcceptor")
  centerInvitationsCreated    CenterInvitation[]          @relation("CenterInvitationCreator")
  familyInvitationsAccepted   FamilyInvitation[]          @relation("FamilyInvitationAcceptor")
  familyInvitationsCreated    FamilyInvitation[]          @relation("FamilyInvitationCreator")
  telegramLoginNonces         TelegramLoginNonce[]
  centerJoinRequests          CenterJoinRequest[]         @relation("JoinRequestParent")
  checkedInAttendanceRecords  AttendanceRecord[]          @relation("AttendanceCheckInBy")
  checkedOutAttendanceRecords AttendanceRecord[]          @relation("AttendanceCheckOutBy")
  childGuardians              ChildGuardian[]
  createdMealPlans            MealPlan[]
  mealChildStatuses           MealChildStatus[]
  mealPosts                   MealPost[]
  createdSchedules            Schedule[]
  dailyReports                DailyReport[]
  dailyReportReads            DailyReportRead[]
  dailyReportComments         DailyReportComment[]
  deviceTokens                DeviceToken[]
  invoices                    Invoice[]
  medicationAdministered      MedicationRequest[]         @relation("MedicationAdministeredBy")
  medicationRequests          MedicationRequest[]         @relation("MedicationParent")
  medicationReviewed          MedicationRequest[]         @relation("MedicationReviewedBy")
  messages                    Message[]
  noticeRecipients            NoticeRecipient[]
  notices                     Notice[]
  pickupAcknowledgements      PickupTimeNotice[]          @relation("PickupAcknowledgedBy")
  pickupTimeNotices           PickupTimeNotice[]          @relation("PickupParent")
  parentProfile               ParentProfile?
  returnHomeConfirmed         ReturnHomeRequest[]         @relation("ReturnHomeConfirmedBy")
  returnHomeRequests          ReturnHomeRequest[]         @relation("ReturnHomeParent")
  reviewedJoinRequests        CenterJoinRequest[]         @relation("JoinRequestReviewer")
  teacherClassAssignments     TeacherClassAssignment[]
  teacherProfile              TeacherProfile?
  threadParticipants          ConversationParticipant[]
  uploadedMediaAssets         MediaAsset[]
  userConsents                UserConsent[]
  userNotificationSettings    UserNotificationSettings?
  userRoles                   UserRole[]
  notifications               Notification[]
  complaintsFiled             Complaint[]                 @relation("ComplaintParent")
  complaintsResolved          Complaint[]                 @relation("ComplaintResolver")
  complaintReplies            ComplaintReply[]
  complaintStatusEvents       ComplaintStatusEvent[]
  realtimeTickets             RealtimeTicket[]
  studentDocumentTemplates    StudentDocumentTemplate[]   @relation("StudentDocumentTemplateCreator")
  studentDocumentRequests     StudentDocumentRequest[]    @relation("StudentDocumentRequestCreator")
  studentDocumentSubmissions  StudentDocumentSubmission[] @relation("StudentDocumentSubmitter")
  reviewedStudentDocuments    StudentDocumentSubmission[] @relation("StudentDocumentReviewer")

  @@map("users")
}

model AuthCredential {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_credentials")
}

model PhoneVerification {
  id                String    @id @default(uuid()) @db.Uuid
  phone             String
  codeHash          String    @map("code_hash")
  verificationToken String?   @unique @map("verification_token")
  attempts          Int       @default(0)
  // "sms" (Eskiz code) or "telegram" (contact shared in the bot, born verified).
  channel           String    @default("sms")
  telegramId        BigInt?   @map("telegram_id")
  telegramUsername  String?   @map("telegram_username")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  verifiedAt        DateTime? @map("verified_at") @db.Timestamptz(6)
  consumedAt        DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone, createdAt])
  @@index([verificationToken])
  @@map("phone_verifications")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  organizationId    String?  @map("organization_id") @db.Uuid
  centerId          String?  @map("center_id") @db.Uuid
  branchId          String?  @map("branch_id") @db.Uuid
  roleId            String   @map("role_id") @db.Uuid
  canApproveMembers Boolean  @default(false) @map("can_approve_members")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  branch       Branch?       @relation(fields: [branchId], references: [id])
  center       Center?       @relation(fields: [centerId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  role         Role          @relation(fields: [roleId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([centerId])
  @@index([branchId])
  @@index([roleId])
  @@map("user_roles")
}

model ParentProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("parent_profiles")
}

model TeacherProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  employeeNumber String?  @map("employee_number")
  bio            String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("teacher_profiles")
}

model UserConsent {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  consentType String    @map("consent_type")
  consented   Boolean
  channel     String?
  consentedAt DateTime? @map("consented_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_consents")
}

model UserNotificationSettings {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  pushEnabled     Boolean   @default(true) @map("push_enabled")
  smsEnabled      Boolean   @default(false) @map("sms_enabled")
  quietHoursStart DateTime? @map("quiet_hours_start") @db.Time(6)
  quietHoursEnd   DateTime? @map("quiet_hours_end") @db.Time(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("user_notification_settings")
}

model Class {
  id           String   @id @default(uuid()) @db.Uuid
  centerId     String   @map("center_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  name         String
  ageGroup     String?  @map("age_group")
  academicYear String?  @map("academic_year")
  maxChildren  Int?     @map("max_children")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  branch                        Branch?                       @relation(fields: [branchId], references: [id])
  center                        Center                        @relation(fields: [centerId], references: [id])
  albumPostClasses              AlbumPostClass[]
  albumPosts                    AlbumPost[]
  attendanceRecords             AttendanceRecord[]
  calendarEventClasses          CalendarEventClass[]
  centerInvitations             CenterInvitation[]
  centerJoinRequests            CenterJoinRequest[]
  childEnrollments              ChildEnrollment[]
  conversationThreads           ConversationThread[]
  complaints                    Complaint[]
  dailyReports                  DailyReport[]
  mealPlans                     MealPlan[]
  mealPostClasses               MealPostClass[]
  medicationRequests            MedicationRequest[]
  notices                       Notice[]
  pickupTimeNotices             PickupTimeNotice[]
  returnHomeRequests            ReturnHomeRequest[]
  schedules                     Schedule[]
  studentDocumentRequestClasses StudentDocumentRequestClass[]
  teacherClassAssignments       TeacherClassAssignment[]

  @@index([centerId])
  @@index([branchId])
  @@map("classes")
}

model TeacherClassAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  teacherUserId  String    @map("teacher_user_id") @db.Uuid
  classId        String    @map("class_id") @db.Uuid
  assignmentRole String    @default("teacher") @map("assignment_role")
  startedAt      DateTime  @default(now()) @map("started_at") @db.Date
  endedAt        DateTime? @map("ended_at") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  class       Class @relation(fields: [classId], references: [id])
  teacherUser User  @relation(fields: [teacherUserId], references: [id])

  @@index([teacherUserId])
  @@index([classId])
  @@map("teacher_class_assignments")
}

model Child {
  id              String   @id @default(uuid()) @db.Uuid
  firstName       String   @map("first_name")
  lastName        String?  @map("last_name")
  dob             DateTime @db.Date
  gender          String?
  photoUrl        String?  @map("photo_url")
  signupClassName String?  @map("signup_class_name")
  allergies       String?
  medicalNotes    String?  @map("medical_notes")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  albumPostChildren              AlbumPostChild[]
  albumMediaChildren             AlbumMediaChild[]
  calendarEventChildren          CalendarEventChild[]
  mealChildStatuses              MealChildStatus[]
  attendanceRecords              AttendanceRecord[]
  centerJoinRequests             CenterJoinRequest[]
  childEnrollments               ChildEnrollment[]
  childGuardians                 ChildGuardian[]
  conversationThreads            ConversationThread[]
  complaints                     Complaint[]
  dailyReports                   DailyReport[]
  invoices                       Invoice[]
  medicationRequests             MedicationRequest[]
  noticeRecipients               NoticeRecipient[]
  pickupTimeNotices              PickupTimeNotice[]
  returnHomeRequests             ReturnHomeRequest[]
  studentDocumentRequestChildren StudentDocumentRequestChild[]
  studentDocumentSubmissions     StudentDocumentSubmission[]

  @@map("children")
}

model ChildGuardian {
  id               String   @id @default(uuid()) @db.Uuid
  childId          String   @map("child_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  relationship     String
  nicknameForChild String?  @map("nickname_for_child")
  isPrimary        Boolean  @default(false) @map("is_primary")
  canPickup        Boolean  @default(false) @map("can_pickup")
  canMessage       Boolean  @default(true) @map("can_message")
  accessLevel      String   @default("full") @map("access_level")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  child Child @relation(fields: [childId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([childId, userId])
  @@index([userId])
  @@map("child_guardians")
}

model ChildEnrollment {
  id               String    @id @default(uuid()) @db.Uuid
  childId          String    @map("child_id") @db.Uuid
  centerId         String    @map("center_id") @db.Uuid
  classId          String?   @map("class_id") @db.Uuid
  enrollmentStatus String    @default("active") @map("enrollment_status")
  startedAt        DateTime  @map("started_at") @db.Date
  endedAt          DateTime? @map("ended_at") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  center Center @relation(fields: [centerId], references: [id])
  child  Child  @relation(fields: [childId], references: [id])
  class  Class? @relation(fields: [classId], references: [id])

  @@index([childId])
  @@index([centerId])
  @@index([classId])
  @@map("child_enrollments")
}

model CenterJoinRequest {
  id                      String    @id @default(uuid()) @db.Uuid
  parentUserId            String    @map("parent_user_id") @db.Uuid
  childId                 String?   @map("child_id") @db.Uuid
  centerId                String    @map("center_id") @db.Uuid
  requestedClassId        String?   @map("requested_class_id") @db.Uuid
  kind                    String    @default("parent")
  childName               String?   @map("child_name")
  childDob                DateTime? @map("child_dob") @db.Date
  childGender             String?   @map("child_gender")
  childPhotoUrl           String?   @map("child_photo_url")
  parentRelationship      String?   @map("parent_relationship")
  customRelationshipLabel String?   @map("custom_relationship_label")
  message                 String?
  status                  String    @default("pending")
  reviewedByUserId        String?   @map("reviewed_by_user_id") @db.Uuid
  reviewedAt              DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewerMessage         String?   @map("reviewer_message")
  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  center         Center @relation(fields: [centerId], references: [id])
  child          Child? @relation(fields: [childId], references: [id])
  parentUser     User   @relation("JoinRequestParent", fields: [parentUserId], references: [id])
  requestedClass Class? @relation(fields: [requestedClassId], references: [id])
  reviewedByUser User?  @relation("JoinRequestReviewer", fields: [reviewedByUserId], references: [id])

  @@index([parentUserId])
  @@index([centerId])
  @@index([requestedClassId])
  @@index([centerId, status, createdAt(sort: Desc)])
  @@map("center_join_requests")
}

model CenterInvitation {
  id               String    @id @default(uuid()) @db.Uuid
  centerId         String    @map("center_id") @db.Uuid
  invitedByUserId  String    @map("invited_by_user_id") @db.Uuid
  kind             String
  classId          String?   @map("class_id") @db.Uuid
  phone            String
  childNameHint    String?   @map("child_name_hint")
  code             String    @unique
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  sentAt           DateTime? @map("sent_at") @db.Timestamptz(6)
  acceptedAt       DateTime? @map("accepted_at") @db.Timestamptz(6)
  acceptedByUserId String?   @map("accepted_by_user_id") @db.Uuid
  declinedAt       DateTime? @map("declined_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  center         Center @relation(fields: [centerId], references: [id])
  class          Class? @relation(fields: [classId], references: [id])
  invitedByUser  User   @relation("CenterInvitationCreator", fields: [invitedByUserId], references: [id])
  acceptedByUser User?  @relation("CenterInvitationAcceptor", fields: [acceptedByUserId], references: [id])

  @@index([centerId, createdAt(sort: Desc)])
  @@index([phone])
  @@map("center_invitations")
}

model FamilyInvitation {
  id                String    @id @default(uuid()) @db.Uuid
  invitedByUserId   String    @map("invited_by_user_id") @db.Uuid
  relationship      String
  code              String
  preferredLanguage String?   @map("preferred_language")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt        DateTime? @map("accepted_at") @db.Timestamptz(6)
  acceptedByUserId  String?   @map("accepted_by_user_id") @db.Uuid
  telegramUserId    BigInt?   @map("telegram_user_id")
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  invitedByUser  User  @relation("FamilyInvitationCreator", fields: [invitedByUserId], references: [id])
  acceptedByUser User? @relation("FamilyInvitationAcceptor", fields: [acceptedByUserId], references: [id])

  @@index([invitedByUserId, createdAt(sort: Desc)])
  @@index([code])
  @@map("family_invitations")
}

model TelegramLoginNonce {
  id                  String    @id @default(uuid()) @db.Uuid
  nonceHash           String    @unique @map("nonce_hash")
  // "login" confirms an existing account; "verify" proves phone ownership at signup.
  purpose             String    @default("login")
  userId              String?   @map("user_id") @db.Uuid
  telegramId          BigInt?   @map("telegram_id")
  phoneVerificationId String?   @map("phone_verification_id") @db.Uuid
  approvedAt          DateTime? @map("approved_at") @db.Timestamptz(6)
  consumedAt          DateTime? @map("consumed_at") @db.Timestamptz(6)
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_login_nonces")
}

model DailyReport {
  id           String    @id @default(uuid()) @db.Uuid
  centerId     String    @map("center_id") @db.Uuid
  classId      String    @map("class_id") @db.Uuid
  childId      String    @map("child_id") @db.Uuid
  authorUserId String    @map("author_user_id") @db.Uuid
  reportDate   DateTime  @map("report_date") @db.Date
  mood         String?
  healthNote   String?   @map("health_note")
  teacherNote  String?   @map("teacher_note")
