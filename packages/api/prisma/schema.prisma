enum ChatRole {
  user
  assistant

  @@map("chat_role")
}

/// Which role a chat thread belongs to. The owner's role selects the scoped
/// toolset (parent = own child, teacher = own classes, director = the center)
/// and keeps a dual-role user's threads separate.
enum ChatOwnerRole {
  parent
  teacher
  director

  @@map("chat_owner_role")
}

/// A user's AI chat conversation. Access is scoped by ownerUserId + ownerRole;
/// the role selects a hard-scoped toolset so the AI can only ever reach the
/// data that owner is already entitled to (see the chat tools services).
model ChatThread {
  id          String        @id @default(uuid()) @db.Uuid
  ownerUserId String        @map("owner_user_id") @db.Uuid
  ownerRole   ChatOwnerRole @default(parent) @map("owner_role")
  childId     String?       @map("child_id") @db.Uuid
  centerId    String        @map("center_id") @db.Uuid
  title       String
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages ChatMessage[]

  @@index([ownerUserId, ownerRole, updatedAt])
  @@map("chat_threads")
}

/// A single turn in a chat thread. `content` is the final text; `toolTrace`
/// records which scoped tools the assistant called (debugging, not shown).
model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  role      ChatRole
  content   String
  language  String?
  toolTrace Json?    @map("tool_trace") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("chat_messages")
}

