DATABASE_URL="postgresql://kichkintoy:kichkintoy_dev_password@localhost:5433/kichkintoy?schema=public"
ESKIZ_BASE_URL="https://notify.eskiz.uz/api"
ESKIZ_EMAIL=""
ESKIZ_PASSWORD=""
ESKIZ_FROM="4546"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_RPC_BASE_URL="http://localhost:4000/rpc"

# --- Private child media storage (MinIO, S3-compatible) ---
MINIO_ENDPOINT="http://localhost:9010"
MINIO_REGION="us-east-1"
MINIO_BUCKET="kichkintoy-media"
MINIO_ACCESS_KEY="kichkintoy_minio"
MINIO_SECRET_KEY="kichkintoy_minio_password"
MINIO_UPLOAD_URL_TTL_SECONDS="300"
MINIO_DOWNLOAD_URL_TTL_SECONDS="300"

# --- Security / hardening ---
# Comma-separated allowlist of browser origins permitted by CORS.
# In production this MUST be set, or all cross-origin requests are rejected (fail closed).
CORS_ORIGINS="http://localhost:3000"
# Max request body size (DoS guard). Default 1mb.
BODY_LIMIT="1mb"
# Reverse-proxy hop count for real client IP (rate limiting / audit). Defaults to 1 in production.
# TRUST_PROXY="1"

# --- OTP demo bypass (DEV ONLY, fails closed in production) ---
# Both must be set for the fixed demo code + returned debugCode to work. Never set in production.
AUTH_ALLOW_DEMO_CODE="true"
AUTH_DEMO_CODE="123456"
