DATABASE_URL="postgresql://kichkintoy:kichkintoy_dev_password@localhost:5433/kichkintoy?schema=public"
ESKIZ_BASE_URL="https://notify.eskiz.uz/api"
ESKIZ_EMAIL=""
ESKIZ_PASSWORD=""
ESKIZ_FROM="4546"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_RPC_BASE_URL="http://localhost:4000/rpc"

# --- Private child media storage (MinIO, S3-compatible) ---
MINIO_ENDPOINT="http://localhost:9010"
MINIO_REGION="us-east-1"
MINIO_BUCKET="kichkintoy-media"
MINIO_ACCESS_KEY="kichkintoy_minio"
MINIO_SECRET_KEY="kichkintoy_minio_password"
MINIO_UPLOAD_URL_TTL_SECONDS="300"
MINIO_DOWNLOAD_URL_TTL_SECONDS="300"

# --- Security / hardening ---
# Comma-separated allowlist of browser origins permitted by CORS.
# In production this MUST be set, or all cross-origin requests are rejected (fail closed).
CORS_ORIGINS="http://localhost:3000"
# Max request body size (DoS guard). Default 1mb.
BODY_LIMIT="1mb"
# Reverse-proxy hop count for real client IP (rate limiting / audit). Defaults to 1 in production.
# TRUST_PROXY="1"

# --- OTP demo bypass (DEV ONLY, fails closed in production) ---
# Both must be set for the fixed demo code + returned debugCode to work. Never set in production.
AUTH_ALLOW_DEMO_CODE="true"
AUTH_DEMO_CODE="123456"

# --- Parent tuition payments (Payme / Click) ---
# Merchant credentials from the provider cabinets. Leave empty until issued;
# the checkout then falls back to the sandbox flow (below) in development.
PAYME_MERCHANT_ID=""
PAYME_MERCHANT_KEY=""
PAYME_CHECKOUT_URL="https://checkout.paycom.uz"
CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""
# Where the provider sends the parent back after checkout.
PAYMENTS_RETURN_URL="http://localhost:3000/dashboard/payments"
# Simulated payments while credentials are missing. Fails closed in production.
PAYMENTS_SANDBOX="true"

# --- AI chatroom (parent / teacher / director) ---
# Default backend is Gemini 2.5 Flash:
GEMINI_API_KEY=""
# To use a free OpenAI-compatible model instead, set CHAT_PROVIDER to a non-"gemini"
# value (openrouter / groq / ollama). The chat is grounded via tool calling, so the
# model MUST support tools (Llama 3.1, Qwen 2.5, DeepSeek — NOT Gemma 2 / Phi-3).
#   OpenRouter: BASE=https://openrouter.ai/api/v1   MODEL=meta-llama/llama-3.1-8b-instruct:free
#   Groq:       BASE=https://api.groq.com/openai/v1 MODEL=llama-3.1-8b-instant
#   Ollama:     BASE=http://localhost:11434/v1      MODEL=llama3.1:8b   (CHAT_API_KEY=ollama)
# CHAT_PROVIDER="openrouter"
# CHAT_BASE_URL="https://openrouter.ai/api/v1"
# CHAT_MODEL="meta-llama/llama-3.1-8b-instruct:free"
# CHAT_API_KEY=""
# OpenRouter only: comma-separated fallback models tried in order when the
# primary is rate-limited upstream (free-pool 429s are common):
# CHAT_MODEL_FALLBACKS="nvidia/nemotron-3-super-120b-a12b:free,meta-llama/llama-3.3-70b-instruct:free"
